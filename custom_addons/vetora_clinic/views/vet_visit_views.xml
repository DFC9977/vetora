<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_vet_visit_tree" model="ir.ui.view">
        <field name="name">vet.visit.list</field>
        <field name="model">vet.visit</field>
        <field name="arch" type="xml">
            <list string="Visits">
                <field name="name"/>
                <field name="start_at"/>
                <field name="pet_id"/>
                <field name="client_id"/>
                <field name="doctor_id"/>
                <field name="service_id"/>
                <field name="status"/>
            </list>
        </field>
    </record>

    <record id="view_vet_visit_form" model="ir.ui.view">
        <field name="name">vet.visit.form</field>
        <field name="model">vet.visit</field>
        <field name="arch" type="xml">
            <form string="Visit">
                <sheet>
                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="pet_id"/>
                            <field name="client_id" readonly="1"/>
                            <field name="doctor_id"/>
                            <field name="service_id"/>
                            <field name="location_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group>
                            <field name="start_at"/>
                            <field name="duration_minutes"/>
                            <field name="end_at" readonly="1"/>
                            <field name="status"/>
                            <field name="source"/>
                            <field name="is_urgent"/>
                        </group>
                    </group>
                    <group>
                        <field name="notes" placeholder="General notes about the visit..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_vet_visit_search" model="ir.ui.view">
        <field name="name">vet.visit.search</field>
        <field name="model">vet.visit</field>
        <field name="arch" type="xml">
            <search string="Search Visits">
                <field name="name"/>
                <field name="pet_id"/>
                <field name="client_id"/>
                <field name="doctor_id"/>
                <field name="service_id"/>
                <field name="status"/>
                <filter string="My Visits" name="my_visits" domain="[('doctor_id.user_id', '=', uid)]"/>
            </search>
        </field>
    </record>

</odoo>
