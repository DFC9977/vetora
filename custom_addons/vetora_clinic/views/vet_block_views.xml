<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_vet_block_list" model="ir.ui.view">
        <field name="name">vet.block.list</field>
        <field name="model">vet.block</field>
        <field name="arch" type="xml">
            <list string="Blocks">
                <field name="block_type"/>
                <field name="doctor_id"/>
                <field name="location_id"/>
                <field name="start_at"/>
                <field name="end_at"/>
                <field name="reason"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_vet_block_form" model="ir.ui.view">
        <field name="name">vet.block.form</field>
        <field name="model">vet.block</field>
        <field name="arch" type="xml">
            <form string="Block">
                <sheet>
                    <group>
                        <group>
                            <field name="block_type"/>
                            <field name="doctor_id"/>
                            <field name="location_id"/>
                            <field name="start_at"/>
                            <field name="end_at"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="reason"/>
                            <field name="is_recurring"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_vet_block_search" model="ir.ui.view">
        <field name="name">vet.block.search</field>
        <field name="model">vet.block</field>
        <field name="arch" type="xml">
            <search string="Search Blocks">
                <field name="doctor_id"/>
                <field name="block_type"/>
                <filter string="Active" name="active" domain="[('active', '=', True)]"/>
                <filter string="Inactive" name="inactive" domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>

</odoo>

