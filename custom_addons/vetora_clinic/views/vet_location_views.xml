<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_vet_location_list" model="ir.ui.view">
        <field name="name">vet.location.list</field>
        <field name="model">vet.location</field>
        <field name="arch" type="xml">
            <list string="Locations">
                <field name="name"/>
                <field name="company_id"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_vet_location_form" model="ir.ui.view">
        <field name="name">vet.location.form</field>
        <field name="model">vet.location</field>
        <field name="arch" type="xml">
            <form string="Location">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="company_id" groups="base.group_multi_company"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

</odoo>

